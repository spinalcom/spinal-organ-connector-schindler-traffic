# ── Spinal Hub ──────────────────────────────────────────────────────────────
SPINAL_USER_ID=168
SPINAL_PASSWORD=
SPINALHUB_IP=
SPINALHUB_PORT=
SPINALHUB_PROTOCOL=http
DIGITALTWIN_PATH=/__users__/admin/Digital twin

SPINAL_ORGAN_NAME=Connector Schindler Traffic
SPINAL_CONFIG_PATH=/etc/Organs/SchindlerTraffic

# ── Virtual network (created if missing) ────────────────────────────────────
NETWORK_NAME=Network Schindler Traffic
VIRTUAL_NETWORK_NAME=Virtual Network Schindler Traffic

# ── BOS navigation to discover elevators ────────────────────────────────────
# The connector walks: Context -> Category -> Group -> BIMObjects,
# then reads an attribute (category + name) holding the Schindler equipmentNumber.
BOS_CONTEXT_NAME=
BOS_CATEGORY_NAME=
BOS_GROUP_NAME=
# Attribute (category + label) holding the equipmentNumber on each BIMObject
EQUIPMENT_ATTR_CATEGORY=
EQUIPMENT_ATTR_NAME=equipmentNumber

# ── Schindler People & Goods Data API ───────────────────────────────────────
# Sandbox:  https://api.schindler.com/traffic/v1-sandbox
# Prod:     https://api.schindler.com/traffic/v1
SCHINDLER_BASE_URL=https://api.schindler.com/traffic/v1-sandbox
SCHINDLER_TOKEN_URL=https://api.schindler.com/colabapplications/v1/identity/token
SCHINDLER_CLIENT_ID=
SCHINDLER_CLIENT_SECRET=
# Optional OAuth2 scope (leave empty if not required)
SCHINDLER_SCOPE=

# ── Backfill & polling ──────────────────────────────────────────────────────
# History pulled on first start, in minutes (e.g. 1440 = 1 day, 10080 = 7 days)
HISTORY_DURATION_MINUTES=1440
# Time bucket size in minutes. Must be a multiple of 5 AND divide 1440
# (valid: 5,10,15,20,30,60,120,240,360,480,720,1440)
RESOLUTION_MINUTES=60
# Polling loop interval in milliseconds (default 5 min)
PULL_INTERVAL=300000
